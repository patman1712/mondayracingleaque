generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum League {
  ONE
  TWO
  ROOKIE
  THREE
  FOUR
  FIVE
  SIX
  SEVEN
  EIGHT
  NINE
  TEN
}

enum SeasonPlacement {
  CALENDAR
  ARCHIVE
}

enum DriverRole {
  MAIN
  RESERVE
}

enum DriverStatus {
  ACTIVE
  RETIRED
}

model NewsPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Driver {
  id        String   @id @default(cuid())
  gamertag  String?
  name      String
  status    DriverStatus @default(ACTIVE)
  number    Int?
  team      String?
  teamId    String?
  country   String?
  portraitPath String?
  starts   Int @default(0)
  wins     Int @default(0)
  podiums  Int @default(0)
  driverOfDay Int @default(0)
  driverTitles Int @default(0)
  constructorTitles Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results RaceResult[]
  seasons DriverSeason[]
  teamRef Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model DriverSeason {
  id       String   @id @default(cuid())
  driverId String
  seasonId String
  teamId   String?
  role     DriverRole @default(MAIN)
  starts   Int @default(0)
  wins     Int @default(0)
  podiums  Int @default(0)
  driverOfDay Int @default(0)
  driverTitles Int @default(0)
  constructorTitles Int @default(0)
  createdAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teamRef Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([driverId, seasonId])
  @@index([seasonId])
  @@index([teamId, seasonId])
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  logoPath  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participations TeamSeason[]
  leagues TeamLeague[]
  driverSeasons DriverSeason[]
  drivers Driver[]
}

model TeamLeague {
  teamId    String
  league    League
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, league])
  @@index([league])
}

model TeamSeason {
  id           String   @id @default(cuid())
  teamId       String
  seasonId     String
  color        String?
  carImagePath String?
  heroBackgroundPath String?
  createdAt    DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([teamId, seasonId])
  @@index([seasonId])
}

model Race {
  id        String   @id @default(cuid())
  league    League
  season    Int
  seasonNo  Int      @default(1)
  seasonIsTest Boolean @default(false)
  round     Int
  name      String
  circuitId String?
  circuit   String?
  location  String?
  startsAt  DateTime
  imagePath String?
  twitchChannel String?
  resultsImagePath String?
  resultsOcrText String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  circuitRef Circuit? @relation(fields: [circuitId], references: [id], onDelete: SetNull)
  results RaceResult[]

  @@unique([league, season, seasonNo, seasonIsTest, round])
}

model RaceResult {
  id         String   @id @default(cuid())
  raceId     String
  driverId   String
  position   Int
  points     Float
  status     String?
  fastestLap Boolean  @default(false)
  createdAt  DateTime @default(now())

  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([raceId, driverId])
  @@unique([raceId, position])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model AppConfig {
  key   String @id
  value String
}

model LeagueConfig {
  league      League  @id
  adminSlug   String  @unique
  publicSlug  String  @unique
  name        String
  accentColor String
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())

  seasons Season[]
}

model Season {
  id    String @id @default(cuid())
  league League @default(ONE)
  year  Int
  seasonNo Int @default(1)
  label String?
  isTest Boolean @default(false)
  placement SeasonPlacement @default(CALENDAR)

  createdAt DateTime @default(now())

  leagueRef LeagueConfig @relation(fields: [league], references: [league], onDelete: Restrict)
  teams TeamSeason[]
  drivers DriverSeason[]

  @@unique([league, year, seasonNo, isTest])
}

model Circuit {
  id       String @id @default(cuid())
  name     String
  location String?
  imagePath String?

  createdAt DateTime @default(now())

  races Race[]

  @@unique([name, location])
}
